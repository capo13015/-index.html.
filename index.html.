function getEloTier(elo){return ELO_TIERS.find(t=>elo>=t.min)||ELO_TIERS[ELO_TIERS.length-1];}
function getRankByXP(xp){let r=RANKS[0];for(const rk of RANKS)if(xp>=rk.min)r=rk;return r;}
function getXPLevel(xp){let lv=1;const thresholds=[0,100,250,500,900,1500,2500,4000,6000,10000];for(const t of thresholds)if(xp>=t)lv++;return lv;}
function getXPProgress(xp){
  const thresholds=[0,100,250,500,900,1500,2500,4000,6000,10000];
  let cur=0,nxt=100;
  for(let i=0;i<thresholds.length-1;i++){if(xp>=thresholds[i]&&xp<thresholds[i+1]){cur=thresholds[i];nxt=thresholds[i+1];break;}}
  if(xp>=10000){cur=10000;nxt=10000;}
  return{cur,nxt,pct:Math.min(100,Math.round((xp-cur)/(nxt-cur)*100))||0};
}

