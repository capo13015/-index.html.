// ══ AI MOVE ══
function doAI(){
  if(over||aiThink)return;
  aiThink=true;
  const ind=document.getElementById('aind');
  ind.classList.add('show');
  ind.className='ai-ind show '+(mode==='demo'?'spec':'ai');
  document.getElementById('aitxt').textContent=L.aithink;
  const[thinkD,chainD]=DEMO_DELAYS[demoSpeed-1];
  const delay=mode==='demo'?thinkD+(Math.random()*150-75):([350,600,1000,1800][diffIdx]+(Math.random()*300-150));
  setTimeout(()=>{
    const mv=getBestMove();
    if(!mv){showWin(cur==='red'?'white':'red');aiThink=false;ind.classList.remove('show');return;}
    const wasKing=board[mv.from[0]][mv.from[1]]?.king;
    board=applyMove(mv,board);draw();
    gameStats.moves++;
    if(mv.cap){showAnn(L.annCap);gameStats.caps++;}
    const isNowKing=board[mv.to[0]][mv.to[1]]?.king;
    if(!wasKing&&isNowKing){setTimeout(()=>showAnn(L.annKing),380);gameStats.kings++;}
    function chain(r,c,depth){
      const ex=getMoves(r,c,board,true);
      if(ex.length&&!over){
        setTimeout(()=>{const cm=ex[Math.floor(Math.random()*ex.length)];board=applyMove(cm,board);draw();
          gameStats.caps++;gameStats.chains++;
          if(depth===0)showAnn(L.annChain);else showAnn(L.annCap);
          chain(cm.to[0],cm.to[1],depth+1);
        },chainD);
      } else {aiThink=false;ind.classList.remove('show');sel=null;moves=[];switchTurn();}
    }
    if(mv.cap)chain(mv.to[0],mv.to[1],0);
    else{aiThink=false;ind.classList.remove('show');sel=null;moves=[];switchTurn();}
  },delay);
}

// ══ PLAYER CLICK ══
function handleClick(r,c){
  if(aiThink||over||mode==='demo')return;
  if(mode==='ai'&&cur==='white')return;
  const p=board[r][c];const am=allMoves(cur,board);
  if(p&&p.col===cur){
    const pm=am.filter(m=>m.from[0]===r&&m.from[1]===c);
    if(!pm.length){setStatus(L.cant);draw();return;}
    sel=[r,c];moves=pm;draw();return;
  }
  if(sel){
    const mv=moves.find(m=>m.to[0]===r&&m.to[1]===c);
    if(mv){
      const wasKing=board[mv.from[0]][mv.from[1]]?.king;
      board=applyMove(mv,board);
      const isNowKing=board[mv.to[0]][mv.to[1]]?.king;
      if(!wasKing&&isNowKing){setTimeout(()=>showAnn(L.annKing),200);gameStats.kings++;}
      gameStats.moves++;
      if(mv.cap){
        gameStats.caps++;
        const ex=getMoves(r,c,board,true);
        if(ex.length){sel=[r,c];moves=ex;setStatus(L.chain(curName()));updateHUD();draw();return;}
        showAnn(L.annCap);
      }
      sel=null;moves=[];switchTurn();return;
    }
    sel=null;moves=[];draw();
  }
}
function switchTurn(){cur=cur==='red'?'white':'red';checkEnd();}
function checkEnd(){
  const rc=count('red'),wc=count('white');
  if(!rc){showWin('white');return;}if(!wc){showWin('red');return;}
  const mv=allMoves(cur,board);if(!mv.length){showWin(cur==='red'?'white':'red');return;}
  updateHUD();
  const isAI=mode==='demo'||(mode==='ai'&&cur==='white');
  if(isAI){
    const hasCap=allCaps(cur,board).length>0;
    setStatus(hasCap?L.cap(curName()):L.sel(curName()));
    if(mode==='demo'&&demoAutoPlay)scheduleAI();
    else if(mode==='ai')setTimeout(doAI,80);
    else if(mode==='demo'&&!demoAutoPlay)setStatus(`<span class="demo-txt">⏸ Appuie sur ▶ pour lancer l'IA</span>`);
  } else refreshStatus();
  draw();
}

// ══ WIN LOGIC ══
function recordResult(playerWon){
  const d=loadD();const opElo=AI_ELO_VALS[diffIdx];const K=mode==='ai'?24:32;
  const newElo=calcElo(d.elo,playerWon,opElo,K);const delta=newElo-d.elo;
  d.elo=Math.max(100,newElo);if(newElo>d.bestElo)d.bestElo=newElo;
  const xpGain=playerWon?(30+diffIdx*20):(diffIdx*5+5);d.xp+=xpGain;
  if(playerWon){d.wins++;if(mode==='ai')d.winsAI++;d.streak++;if(d.streak>d.bestStreak)d.bestStreak=d.streak;d.dameWon+=stake;}
  else{d.losses++;if(mode==='ai')d.lossesAI++;d.streak=0;d.dameLost+=stake;}
  d.history.push({result:playerWon?'win':'loss',opponent:mode==='ai'?`IA ${['Débutant','Moyen','Expert','Pro'][diffIdx]}`:'Joueur 2',mode:mode==='ai'?'Solo IA':'1vs1',eloDelta:delta,elo:d.elo,ts:Date.now()});
  d.coachData={...gameStats,won:playerWon,caps:gameStats.caps,chains:gameStats.chains,kings:gameStats.kings,moves:gameStats.moves};
  saveD(d);refreshHeader();
  return{newElo:d.elo,delta,xpGain};
}
function recordDemo(playerWon){
  const d=loadD();const xpGain=playerWon?10:5;d.xp+=xpGain;
  d.coachData={...gameStats,won:playerWon};
  d.history.push({result:playerWon?'win':'loss',opponent:'IA Démo',mode:'Démo',eloDelta:0,elo:d.elo,ts:Date.now()});
  saveD(d);refreshHeader();return{xpGain};
}

function showWin(w){
  over=true;aiThink=false;stopAuto();
  document.getElementById('aind').classList.remove('show');
  const isDemo=mode==='demo';
  const playerWon=w==='red'&&mode!=='demo';
  let eloRes=null,xpGain=10;
  if(!isDemo&&(mode==='ai'||mode==='pvp')){eloRes=recordResult(playerWon);}
  else if(isDemo){const r=recordDemo(w==='red');xpGain=r.xpGain;}

  const wcard=document.getElementById('wcard');
  wcard.className='wcard'+(isDemo?' demo':'');
  if(!isDemo&&!playerWon)wcard.classList.add('loss');
  document.getElementById('wicon').textContent=w==='red'?'🏆':(mode==='ai'?'🤖':'🏆');
  const wtEl=document.getElementById('wtitle');
  wtEl.className='wtitle'+(isDemo?' demo':(!playerWon&&!isDemo?' loss':''));
  wtEl.textContent=isDemo?L.wts(w):L.wt(w);
  document.getElementById('wstake').textContent=L.ws(w,stake,mode==='ai',isDemo);
  document.getElementById('wstake').style.color=w==='red'?'var(--gold)':(isDemo?'var(--purple)':'var(--red)');
  // ELO row
  const eloRow=document.getElementById('w-elo-row');
  if(eloRes&&!isDemo){
    document.getElementById('w-elo-new').textContent=eloRes.newElo;
    const dc=document.getElementById('w-elo-delta');dc.textContent=(eloRes.delta>=0?'+':'')+eloRes.delta;
    dc.style.color=eloRes.delta>=0?'var(--green)':'var(--red)';
    eloRow.style.display='inline-flex';
  } else eloRow.style.display='none';
  // XP row
  const xpToUse=eloRes?eloRes.xpGain:xpGain;
  document.getElementById('w-xp').textContent=xpToUse;
  document.getElementById('wmsg').textContent=L.wm(w,stake,mode==='ai',isDemo);
  document.getElementById('win-overlay').classList.add('show');
  draw();
}

function setStatus(h){document.getElementById('sb').innerHTML=h;}
function curName(){
  if(mode==='demo')return cur==='red'?L.p1sk:L.p2sk;
  return cur==='red'?L.p1k:(mode==='ai'?L.p2aik:L.p2k);
}
function refreshStatus(){
  if(over)return;const hasCap=allCaps(cur,board).length>0;
  setStatus(hasCap?L.cap(curName()):L.sel(curName()));
}
function updateHUD(){
  const rc=count('red'),wc=count('white');const isDemo=mode==='demo';
  const d=loadD();
  document.getElementById('p1n').textContent=isDemo?L.p1s:(mode==='pvp'?L.p1:d.name||L.p1);
  document.getElementById('p2n').textContent=isDemo?L.p2s:(mode==='ai'?L.p2ai:L.p2);
  document.getElementById('pl').textContent=L.pl;
  document.querySelectorAll('.pl2').forEach(e=>e.textContent=L.pl);
  document.getElementById('rc').textContent=rc;document.getElementById('wc').textContent=wc;
  dots('rd',rc,isDemo?'r':'r');dots('wd',wc,isDemo?'b':'w');
  document.getElementById('h1').classList.toggle('on',cur==='red'&&!over);
  document.getElementById('h2').classList.toggle('on',cur==='white'&&!over);
  document.getElementById('tt').textContent=cur==='red'?L.tl(curName()):L.tr(curName());
  // Update stake badge
  const stk=document.getElementById('sb2');
  stk.className='stk'+(isDemo?' demo':'');
  stk.textContent=isDemo?'DÉMO':`$${stake}`;
}
function dots(id,n,cls){
  const el=document.getElementById(id);el.innerHTML='';
  for(let i=0;i<Math.min(n,12);i++){const d=document.createElement('div');d.className=`pd ${cls}`;el.appendChild(d);}
}
function resetGame(){
  over=false;aiThink=false;cur='red';sel=null;moves=[];stopAuto();
  document.getElementById('aind').classList.remove('show');
  document.getElementById('win-overlay').classList.remove('show');
  document.getElementById('ann').style.display='none';
  initBoard();updateHUD();
  const isDemo=mode==='demo';
  if(isDemo&&demoAutoPlay){setStatus(`<span class="demo-txt">🎮 IA-1 vs IA-2…</span>`);setTimeout(scheduleAI,600);}
  else if(isDemo)setStatus(`<span class="demo-txt">🎮 Démo — Appuie ▶ pour l'IA auto</span>`);
  else setStatus(L.starts(curName()));
  draw();
}

// ══ CANVAS ══
const cv=document.getElementById('board');
const ctx=cv.getContext('2d');
let CS=60;
function resize(){
  const wrap=document.querySelector('.board-wrap');
  const avail=Math.min(wrap.clientWidth-12,wrap.clientHeight-12);
  CS=Math.max(28,Math.floor(avail/8));
  cv.width=cv.height=CS*8;draw();
}
function draw(){
  if(!cv.width)return;
  const possSet=new Set(moves.map(m=>`${m.to[0]},${m.to[1]}`));
  for(let r=0;r<8;r++)for(let c=0;c<8;c++){
    const light=(r+c)%2===0;ctx.fillStyle=light?'#EDD89A':'#B07540';ctx.fillRect(c*CS,r*CS,CS,CS);
    if(sel&&sel[0]===r&&sel[1]===c){ctx.fillStyle='rgba(200,230,80,.45)';ctx.fillRect(c*CS,r*CS,CS,CS);}
    if(possSet.has(`${r},${c}`)){ctx.fillStyle='rgba(80,210,80,.32)';ctx.fillRect(c*CS,r*CS,CS,CS);ctx.beginPath();ctx.arc(c*CS+CS/2,r*CS+CS/2,CS*.16,0,Math.PI*2);ctx.fillStyle='rgba(50,160,50,.55)';ctx.fill();}
  }
  for(let r=0;r<8;r++)for(let c=0;c<8;c++){
    const p=board[r][c];if(!p)continue;
    const x=c*CS+CS/2,y=r*CS+CS/2,rad=CS*.37;
    const isSel=sel&&sel[0]===r&&sel[1]===c;
    const isBlue=mode==='demo'&&p.col==='white';
    ctx.beginPath();ctx.arc(x+1,y+2,rad,0,Math.PI*2);ctx.fillStyle='rgba(0,0,0,.3)';ctx.fill();
    let g;
    if(p.col==='red'){g=ctx.createRadialGradient(x-rad*.3,y-rad*.3,rad*.1,x,y,rad);g.addColorStop(0,'#F87171');g.addColorStop(.5,'#DC2626');g.addColorStop(1,'#7F1D1D');}
    else if(isBlue){g=ctx.createRadialGradient(x-rad*.3,y-rad*.3,rad*.1,x,y,rad);g.addColorStop(0,'#93C5FD');g.addColorStop(.5,'#3B82F6');g.addColorStop(1,'#1E3A8A');}
    else{g=ctx.createRadialGradient(x-rad*.3,y-rad*.3,rad*.1,x,y,rad);g.addColorStop(0,'#F8FAFC');g.addColorStop(.5,'#CBD5E1');g.addColorStop(1,'#64748B');}
    ctx.beginPath();ctx.arc(x,y,rad,0,Math.PI*2);ctx.fillStyle=g;ctx.fill();
    ctx.strokeStyle=isSel?'#D4AF37':p.king?'#FCD34D':(p.col==='red'?'#991B1B':isBlue?'#1D4ED8':'#475569');
    ctx.lineWidth=isSel?2.5:p.king?2:1.5;ctx.stroke();
    if(isSel){ctx.beginPath();ctx.arc(x,y,rad+3,0,Math.PI*2);ctx.strokeStyle='rgba(212,175,55,.5)';ctx.lineWidth=2;ctx.stroke();}
    ctx.fillStyle=p.col==='red'?'rgba(255,200,200,.4)':(isBlue?'rgba(180,220,255,.4)':'rgba(100,116,139,.4)');
    ctx.font=`bold ${Math.max(10,CS*.32)}px serif`;ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(p.king?'♛':'♞',x,y+1);
  }
}
function cellAt(px,py){
  const rect=cv.getBoundingClientRect();const x=px-rect.left,y=py-rect.top;
  if(x<0||x>cv.width||y<0||y>cv.height)return null;
  return[Math.floor(y/CS),Math.floor(x/CS)];
}
cv.addEventListener('click',e=>{const c=cellAt(e.clientX,e.clientY);if(c)handleClick(c[0],c[1]);});
cv.addEventListener('touchend',e=>{e.preventDefault();const t=e.changedTouches[0];const c=cellAt(t.clientX,t.clientY);if(c)handleClick(c[0],c[1]);},{passive:false});
window.addEventListener('resize',()=>{resize();});

