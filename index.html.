}
function getMoves(r,c,b,capOnly=false){
  const p=b[r][c];if(!p)return[];
  const mv=[],cp=[];const dirs=[];
  if(p.col==='red'||p.king)dirs.push([-1,-1],[-1,1]);
  if(p.col==='white'||p.king)dirs.push([1,-1],[1,1]);
  for(const[dr,dc]of dirs){
    const nr=r+dr,nc=c+dc;
    if(nr>=0&&nr<8&&nc>=0&&nc<8){
      if(!b[nr][nc])mv.push({from:[r,c],to:[nr,nc],cap:null});
      else if(b[nr][nc].col!==p.col){const jr=r+2*dr,jc=c+2*dc;if(jr>=0&&jr<8&&jc>=0&&jc<8&&!b[jr][jc])cp.push({from:[r,c],to:[jr,jc],cap:[nr,nc]});}
    }
  }
  if(capOnly)return cp;return cp.length?cp:mv;
}
function allCaps(col,b){const a=[];for(let r=0;r<8;r++)for(let c=0;c<8;c++)if(b[r][c]?.col===col)a.push(...getMoves(r,c,b,true));return a;}
function allMoves(col,b){const c=allCaps(col,b);if(c.length)return c;const m=[];for(let r=0;r<8;r++)for(let c2=0;c2<8;c2++)if(b[r][c2]?.col===col)m.push(...getMoves(r,c2,b));return m;}
function applyMove(mv,b){
  const nb=b.map(row=>row.map(c=>c?{...c}:null));
  const[fr,fc]=mv.from,[tr,tc]=mv.to;
  nb[tr][tc]=nb[fr][fc];nb[fr][fc]=null;
  if(mv.cap)nb[mv.cap[0]][mv.cap[1]]=null;
  if(nb[tr][tc].col==='red'&&tr===0)nb[tr][tc].king=true;
  if(nb[tr][tc].col==='white'&&tr===7)nb[tr][tc].king=true;
  return nb;
}
function count(col,b=board){let n=0;for(let r=0;r<8;r++)for(let c=0;c<8;c++)if(b[r][c]?.col===col)n++;return n;}

// ══ AI ENGINE ══
function evalB(b){
  let s=0;
  for(let r=0;r<8;r++)for(let c=0;c<8;c++){
    const p=b[r][c];if(!p)continue;
    let v=p.king?3:1;v+=(p.col==='white'?(r/7):(1-r/7))*0.3;v+=(1-Math.abs(c-3.5)/3.5)*0.1;
    s+=p.col==='white'?v:-v;
  }
  return s;
}
function mm(b,d,a,be,isMax){
  const col=isMax?'white':'red',mv=allMoves(col,b);
  if(d===0||!mv.length){const rc=count('red',b),wc=count('white',b);if(!rc)return 1000;if(!wc)return-1000;return evalB(b);}
  if(isMax){let best=-Infinity;for(const m of mv){const nb=applyMove(m,b);const v=mm(nb,d-1,a,be,false);best=Math.max(best,v);a=Math.max(a,v);if(be<=a)break;}return best;}
  else{let best=Infinity;for(const m of mv){const nb=applyMove(m,b);const v=mm(nb,d-1,a,be,true);best=Math.min(best,v);be=Math.min(be,v);if(be<=a)break;}return best;}
}
function getBestMove(){
  const mv=allMoves(cur,board);if(!mv.length)return null;
  const d=DEPTHS[diffIdx];
  if(d===0){const caps=allCaps(cur,board);const pool=caps.length?caps:mv;return pool[Math.floor(Math.random()*pool.length)];}
  if(d===2){const sign=cur==='white'?1:-1;let best=-Infinity,bm=mv[0];for(const m of mv){const nb=applyMove(m,board);let v=evalB(nb)*sign+(m.cap?1.5:0)+(Math.random()*.2);if(v>best){best=v;bm=m;}}return bm;}
  const isMax=cur==='white';let best=isMax?-Infinity:Infinity,bm=mv[0];
  const sh=[...mv].sort(()=>Math.random()-.5);
  for(const m of sh){const nb=applyMove(m,board);const v=mm(nb,d-1,-Infinity,Infinity,!isMax);if(isMax?v>best:v<best){best=v;bm=m;}}
  return bm;
}

