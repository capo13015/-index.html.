<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>DAMECOIN — Jeu de Dames</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Inter:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap');
:root{
  --gold:#D4AF37;--gold-light:#F5D76E;--gold-dark:#A08820;
  --bg:#08070A;--surface:#0F0D18;--surface2:#181428;--border:#242038;
  --text:#EBE4F0;--muted:#6B6080;--green:#22D87A;--purple:#8B5CF6;
  --pink:#EC4899;--blue:#60A5FA;--orange:#FB923C;--red:#F87171;
  --xp:#FCD34D;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;background:var(--bg);font-family:'Inter',sans-serif;color:var(--text);overflow:hidden;}
body{display:flex;flex-direction:column;max-width:100vw;}

/* ═══ RISK BANNER ═══ */
#risk-banner{background:linear-gradient(90deg,rgba(251,146,60,.12),rgba(248,113,113,.1));border-bottom:1px solid rgba(251,146,60,.25);padding:5px 14px;display:flex;align-items:center;justify-content:center;gap:8px;font-size:10px;color:rgba(253,186,116,.85);flex-shrink:0;text-align:center;flex-wrap:wrap;line-height:1.4;}
#risk-banner strong{color:#FCD34D;}
#risk-banner .rb-close{cursor:pointer;opacity:.5;font-size:14px;margin-left:6px;flex-shrink:0;}
#risk-banner .rb-close:hover{opacity:1;}

/* ═══ HEADER ═══ */
header{display:flex;align-items:center;padding:0 12px;background:rgba(8,7,10,.97);border-bottom:1px solid var(--border);flex-shrink:0;height:46px;gap:8px;}
.logo{font-family:'Cinzel',serif;font-size:16px;font-weight:900;background:linear-gradient(135deg,var(--gold-dark),var(--gold-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:2px;flex-shrink:0;}
.mode-pill{border-radius:10px;padding:2px 8px;font-size:8px;font-weight:700;letter-spacing:1px;text-transform:uppercase;flex-shrink:0;}
.pill-demo{background:rgba(139,92,246,.15);border:1px solid rgba(139,92,246,.3);color:var(--purple);}
.pill-ai{background:rgba(34,216,122,.12);border:1px solid rgba(34,216,122,.25);color:var(--green);}
.pill-pvp{background:rgba(212,175,55,.1);border:1px solid rgba(212,175,55,.25);color:var(--gold);}
.pill-spec{background:rgba(96,165,250,.12);border:1px solid rgba(96,165,250,.25);color:var(--blue);}
.header-center{flex:1;}
.langs{display:flex;gap:3px;}
.lb{background:transparent;border:1px solid var(--border);border-radius:5px;color:var(--text);font-size:11px;cursor:pointer;padding:2px 5px;transition:all .2s;line-height:1;}
.lb:hover,.lb.on{border-color:var(--gold);background:rgba(212,175,55,.1);}
.hdr-xp{display:flex;align-items:center;gap:5px;flex-shrink:0;}
.hdr-xp-av{width:26px;height:26px;border-radius:50%;border:1.5px solid var(--gold-dark);background:var(--surface2);font-size:14px;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;}
.hdr-xp-info{display:flex;flex-direction:column;gap:1px;}
.hdr-xp-name{font-size:9px;font-weight:600;color:var(--text);line-height:1;max-width:60px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.hdr-xp-bar-wrap{width:56px;height:4px;background:var(--border);border-radius:2px;overflow:hidden;}
.hdr-xp-bar{height:100%;background:linear-gradient(90deg,var(--gold-dark),var(--xp));border-radius:2px;transition:width .5s ease;}
.hdr-xp-lvl{font-size:8px;color:var(--xp);font-weight:700;line-height:1;}

/* ═══ HUD ═══ */
.hud{display:flex;gap:5px;padding:5px 10px;flex-shrink:0;}
.phud{flex:1;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:6px 10px;transition:all .3s;min-width:0;}
.phud.on{border-color:var(--gold-dark);box-shadow:0 0 14px rgba(212,175,55,.1);}
.pn{font-family:'Cinzel',serif;font-size:10px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.pc{font-size:9px;color:var(--muted);margin-top:1px;}
.pdots{display:flex;flex-wrap:wrap;gap:2px;margin-top:3px;}
.pd{width:5px;height:5px;border-radius:50%;}
.pd.r{background:radial-gradient(circle at 35% 35%,#EF4444,#7F1D1D);}
.pd.w{background:radial-gradient(circle at 35% 35%,#F8FAFC,#94A3B8);}
.pd.b{background:radial-gradient(circle at 35% 35%,#60A5FA,#1D4ED8);}
.hcenter{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:3px 6px;gap:2px;flex-shrink:0;}
.vs{font-family:'Cinzel',serif;font-size:12px;color:var(--gold-dark);font-weight:700;}
.stk{font-size:7px;font-weight:700;padding:1px 5px;border-radius:3px;background:rgba(212,175,55,.1);border:1px solid rgba(212,175,55,.2);color:var(--gold);}
.stk.demo{background:rgba(139,92,246,.1);border-color:rgba(139,92,246,.25);color:var(--purple);}
.stk.spec{background:rgba(96,165,250,.1);border-color:rgba(96,165,250,.25);color:var(--blue);}
.ttxt{font-size:7px;color:var(--green);font-weight:600;}

/* ═══ STATUS ═══ */
#sb{text-align:center;font-size:11px;padding:3px 10px;flex-shrink:0;min-height:22px;}
.hl{color:var(--gold);font-family:'Cinzel',serif;}
.ai-txt{color:var(--green);font-style:italic;}
.demo-txt{color:var(--purple);font-style:italic;}
.spec-txt{color:var(--blue);font-style:italic;}

/* ═══ BOARD ═══ */
.board-wrap{flex:1;display:flex;align-items:center;justify-content:center;padding:6px;position:relative;overflow:hidden;min-height:0;}
canvas#board{border-radius:6px;box-shadow:0 0 24px rgba(0,0,0,.8),0 0 0 2px #3A2A10,0 0 0 3px #5C3E1A;max-width:100%;max-height:100%;display:block;}
.ai-ind{position:absolute;top:8px;left:50%;transform:translateX(-50%);border-radius:20px;padding:3px 12px;font-size:10px;display:none;align-items:center;gap:5px;white-space:nowrap;}
.ai-ind.show{display:flex;}
.ai-ind.ai{background:rgba(34,216,122,.13);border:1px solid rgba(34,216,122,.28);color:var(--green);}
.ai-ind.spec{background:rgba(96,165,250,.13);border:1px solid rgba(96,165,250,.28);color:var(--blue);}
.aidot{width:5px;height:5px;border-radius:50%;animation:ap .7s ease-in-out infinite;}
.ai-ind.ai .aidot{background:var(--green);}
.ai-ind.spec .aidot{background:var(--blue);}
.aidot:nth-child(2){animation-delay:.2s;}.aidot:nth-child(3){animation-delay:.4s;}
@keyframes ap{0%,100%{opacity:.3;transform:scale(.7)}50%{opacity:1;transform:scale(1.2)}}
#ann{position:absolute;bottom:10px;left:50%;transform:translateX(-50%);background:rgba(139,92,246,.2);border:1px solid rgba(139,92,246,.4);border-radius:10px;padding:4px 12px;font-size:10px;color:#C4B5FD;display:none;white-space:nowrap;font-weight:600;pointer-events:none;animation:annIn .4s ease;}
@keyframes annIn{from{opacity:0;transform:translateX(-50%) translateY(6px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}

/* ═══ CTRL BAR ═══ */
.ctrl{display:flex;gap:4px;padding:5px 8px;flex-shrink:0;background:rgba(8,7,10,.95);border-top:1px solid var(--border);}
.btn{flex:1;padding:6px 4px;border-radius:7px;font-size:9px;font-weight:600;letter-spacing:.3px;text-transform:uppercase;cursor:pointer;border:1px solid var(--border);transition:all .2s;font-family:'Inter',sans-serif;white-space:nowrap;}
.bgold{background:linear-gradient(135deg,var(--gold-dark),var(--gold));color:#1A1000;border-color:var(--gold);}
.bgold:hover{box-shadow:0 2px 10px rgba(212,175,55,.3);transform:translateY(-1px);}
.bghost{background:transparent;color:var(--text);}
.bghost:hover{background:rgba(212,175,55,.05);border-color:rgba(212,175,55,.2);}
.bgreen{background:rgba(34,216,122,.08);color:var(--green);border-color:rgba(34,216,122,.22);}
.bpurple{background:rgba(139,92,246,.08);color:var(--purple);border-color:rgba(139,92,246,.22);}
.bblue{background:rgba(96,165,250,.08);color:var(--blue);border-color:rgba(96,165,250,.22);}

/* ═══ OVERLAY BASE ═══ */
.overlay{position:fixed;inset:0;background:rgba(5,4,9,.95);z-index:200;display:none;align-items:center;justify-content:center;backdrop-filter:blur(8px);}
.overlay.show{display:flex;}
.ocard{width:min(480px,96vw);max-height:96vh;overflow-y:auto;background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:18px 16px;box-shadow:0 0 60px rgba(0,0,0,.5);animation:fadeUp .3s ease;}
@keyframes fadeUp{from{transform:translateY(18px);opacity:0}to{transform:translateY(0);opacity:1}}
.ocard::-webkit-scrollbar{width:3px;}
.ocard::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}
.ocard-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.ocard-title{font-family:'Cinzel',serif;font-size:18px;font-weight:900;background:linear-gradient(135deg,var(--gold-dark),var(--gold-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:2px;}
.ocard-close{cursor:pointer;color:var(--muted);font-size:20px;line-height:1;padding:2px 7px;border-radius:6px;transition:all .2s;border:none;background:transparent;}
.ocard-close:hover{color:var(--text);background:rgba(255,255,255,.06);}
.sec-label{font-family:'Cinzel',serif;font-size:8px;letter-spacing:3px;color:var(--gold-dark);text-transform:uppercase;margin-bottom:6px;}

/* TABS */
.tabs{display:flex;gap:3px;background:rgba(255,255,255,.02);border:1px solid var(--border);border-radius:9px;padding:3px;margin-bottom:12px;}
.tab{flex:1;padding:6px;text-align:center;cursor:pointer;border-radius:6px;font-size:10px;font-weight:600;color:var(--muted);transition:all .2s;border:none;background:transparent;}
.tab:hover{color:var(--text);}
.tab.on{background:var(--surface2);color:var(--gold);}
.tpane{display:none;}
.tpane.on{display:block;}

/* ═══ MENU ═══ */
.menu-logo{font-family:'Cinzel',serif;font-size:22px;font-weight:900;text-align:center;background:linear-gradient(135deg,var(--gold-dark),var(--gold-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:4px;margin-bottom:2px;}
.menu-sub{text-align:center;font-size:8px;color:var(--green);letter-spacing:3px;margin-bottom:12px;}

/* Mode grid */
.mgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:5px;margin-bottom:12px;}
.mc{background:rgba(255,255,255,.02);border:1px solid var(--border);border-radius:9px;padding:10px 5px;text-align:center;cursor:pointer;transition:all .2s;position:relative;}
.mc:hover{border-color:rgba(212,175,55,.3);transform:translateY(-1px);}
.mc.on{border-color:var(--gold);background:rgba(212,175,55,.07);}
.mc.on::after{content:'✓';position:absolute;top:5px;right:6px;font-size:8px;color:var(--gold);}
.mc.mc-demo.on{border-color:var(--purple);background:rgba(139,92,246,.1);}
.mc.mc-spec.on{border-color:var(--blue);background:rgba(96,165,250,.1);}
.mi{font-size:20px;margin-bottom:3px;}
.mt{font-family:'Cinzel',serif;font-size:9px;font-weight:700;}
.md{font-size:7px;color:var(--muted);margin-top:2px;line-height:1.3;}
.mc.mc-demo .md,.mc.mc-demo .mt{color:#C4B5FD;}
.mc.mc-spec .md,.mc.mc-spec .mt{color:var(--blue);}

/* diff */
.dgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;margin-bottom:10px;}
.db{background:rgba(255,255,255,.02);border:1px solid var(--border);border-radius:7px;padding:6px 3px;text-align:center;cursor:pointer;transition:all .2s;}
.db:hover{border-color:rgba(212,175,55,.3);}
.db.on{border-color:var(--gold);background:rgba(212,175,55,.07);}
.di{font-size:13px;margin-bottom:2px;}
.dn{font-size:8px;font-weight:700;}
.de{font-size:7px;color:var(--muted);}

/* stakes */
.spresets{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:8px;}
.sp{background:rgba(255,255,255,.02);border:1px solid var(--border);border-radius:5px;padding:4px 8px;cursor:pointer;font-size:11px;font-weight:600;transition:all .2s;}
.sp:hover{border-color:rgba(212,175,55,.3);}
.sp.on{border-color:var(--gold);background:rgba(212,175,55,.07);color:var(--gold);}

/* speed */
.speed-btns{display:flex;gap:4px;}
.spd{background:rgba(255,255,255,.02);border:1px solid var(--border);border-radius:5px;padding:4px 9px;cursor:pointer;font-size:9px;font-weight:600;color:var(--text);transition:all .2s;}
.spd:hover{border-color:rgba(139,92,246,.4);}
.spd.on{border-color:var(--purple);background:rgba(139,92,246,.08);color:#C4B5FD;}

/* profile mini */
.pinput{width:100%;background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:7px;padding:8px 11px;color:var(--text);font-family:'Inter',sans-serif;font-size:13px;outline:none;transition:border-color .2s;margin-bottom:8px;}
.pinput:focus{border-color:rgba(212,175,55,.3);}
.av-row{display:flex;gap:6px;flex-wrap:wrap;}
.av{width:32px;height:32px;border-radius:50%;border:2px solid var(--border);background:var(--surface2);cursor:pointer;font-size:17px;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.av:hover{border-color:rgba(212,175,55,.3);}
.av.on{border-color:var(--gold);background:rgba(212,175,55,.1);box-shadow:0 0 10px rgba(212,175,55,.2);}

/* btn styles */
.btn-solid{width:100%;padding:11px;border-radius:9px;background:linear-gradient(135deg,var(--gold-dark),var(--gold));color:#1A1000;border:none;font-family:'Cinzel',serif;font-size:12px;font-weight:700;letter-spacing:1px;cursor:pointer;box-shadow:0 4px 14px rgba(212,175,55,.18);transition:all .2s;margin-top:6px;}
.btn-solid:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(212,175,55,.26);}
.btn-outline{width:100%;padding:10px;border-radius:9px;background:transparent;color:var(--purple);border:1px solid rgba(139,92,246,.3);font-family:'Cinzel',serif;font-size:11px;font-weight:700;cursor:pointer;transition:all .2s;margin-top:5px;}
.btn-outline:hover{background:rgba(139,92,246,.1);border-color:rgba(139,92,246,.5);}
.btn-row2{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:6px;}
.btn-half{padding:10px;border-radius:8px;font-family:'Cinzel',serif;font-size:10px;font-weight:700;cursor:pointer;border:none;transition:all .2s;}
.btn-half.gold{background:linear-gradient(135deg,var(--gold-dark),var(--gold));color:#1A1000;}
.btn-half.purple{background:rgba(139,92,246,.12);color:#C4B5FD;border:1px solid rgba(139,92,246,.3);}
.btn-half.blue{background:rgba(96,165,250,.1);color:var(--blue);border:1px solid rgba(96,165,250,.25);}
.btn-half:hover{transform:translateY(-1px);}

/* ═══ XP / RANKS ═══ */
.xp-card{background:var(--surface2);border:1px solid var(--border);border-radius:12px;padding:14px;margin-bottom:10px;}
.xp-top{display:flex;align-items:center;gap:12px;margin-bottom:10px;}
.xp-avatar-big{width:52px;height:52px;border-radius:50%;border:2px solid var(--gold-dark);background:var(--surface);font-size:26px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.xp-main{flex:1;}
.xp-name{font-family:'Cinzel',serif;font-size:15px;font-weight:700;margin-bottom:2px;}
.xp-tier{font-size:11px;font-weight:600;margin-bottom:4px;}
.xp-bar-wrap{background:var(--border);border-radius:3px;height:7px;overflow:hidden;}
.xp-bar{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--gold-dark),var(--xp));transition:width .6s ease;}
.xp-numbers{display:flex;justify-content:space-between;font-size:9px;color:var(--muted);margin-top:3px;}
.xp-elo-row{display:flex;align-items:center;gap:8px;font-family:'Space Mono',monospace;font-size:12px;}
.xp-elo-val{color:var(--gold);font-weight:700;}
.xp-elo-delta{font-size:10px;padding:1px 6px;border-radius:4px;}
.xp-elo-delta.pos{background:rgba(34,216,122,.1);color:var(--green);}
.xp-elo-delta.neg{background:rgba(248,113,113,.1);color:var(--red);}

/* ═══ RANKS DISPLAY ═══ */
.ranks-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:10px;}
.rank-card{background:var(--surface2);border:1px solid var(--border);border-radius:9px;padding:10px 7px;text-align:center;transition:all .2s;}
.rank-card.unlocked{border-color:rgba(212,175,55,.25);}
.rank-card.current{border-color:var(--gold);background:rgba(212,175,55,.06);box-shadow:0 0 12px rgba(212,175,55,.1);}
.rank-icon{font-size:22px;margin-bottom:4px;}
.rank-name{font-size:9px;font-weight:700;margin-bottom:2px;}
.rank-req{font-size:8px;color:var(--muted);}
.rank-locked{opacity:.35;}

/* ═══ SEASON REWARDS ═══ */
.season-header{background:linear-gradient(135deg,rgba(139,92,246,.15),rgba(236,72,153,.1));border:1px solid rgba(139,92,246,.25);border-radius:12px;padding:12px 14px;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;}
.season-title{font-family:'Cinzel',serif;font-size:13px;font-weight:700;color:var(--purple);}
.season-timer{font-family:'Space Mono',monospace;font-size:11px;color:var(--pink);background:rgba(236,72,153,.08);border:1px solid rgba(236,72,153,.2);border-radius:6px;padding:2px 8px;}
.reward-track{display:flex;gap:0;position:relative;margin-bottom:8px;overflow-x:auto;padding-bottom:4px;}
.reward-track::-webkit-scrollbar{height:2px;}
.reward-track::-webkit-scrollbar-thumb{background:var(--border);}
.reward-node{display:flex;flex-direction:column;align-items:center;min-width:64px;position:relative;}
.reward-node::before{content:'';position:absolute;top:16px;left:50%;width:100%;height:2px;background:var(--border);z-index:0;}
.reward-node:last-child::before{display:none;}
.reward-node.done::before{background:linear-gradient(90deg,var(--gold-dark),var(--gold));}
.rn-icon{width:32px;height:32px;border-radius:50%;border:2px solid var(--border);background:var(--surface);display:flex;align-items:center;justify-content:center;font-size:14px;position:relative;z-index:1;transition:all .3s;}
.reward-node.done .rn-icon{border-color:var(--gold);background:rgba(212,175,55,.1);}
.reward-node.current .rn-icon{border-color:var(--purple);background:rgba(139,92,246,.15);box-shadow:0 0 10px rgba(139,92,246,.3);}
.rn-label{font-size:7px;color:var(--muted);margin-top:4px;text-align:center;line-height:1.3;}
.rn-xp{font-size:7px;color:var(--xp);font-weight:700;}

/* ═══ LEADERBOARD ═══ */
.lb-list{display:flex;flex-direction:column;gap:5px;}
.lb-row{display:grid;grid-template-columns:28px 1fr auto;gap:8px;align-items:center;background:var(--surface2);border:1px solid var(--border);border-radius:9px;padding:9px 11px;transition:all .2s;}
.lb-row:hover{border-color:rgba(212,175,55,.12);}
.lb-row.me{border-color:rgba(212,175,55,.35);background:rgba(212,175,55,.04);}
.lb-row.t1{border-color:rgba(255,215,0,.35);background:rgba(255,215,0,.04);}
.lb-row.t2{border-color:rgba(192,192,192,.25);}
.lb-row.t3{border-color:rgba(205,127,50,.25);}
.lb-rank{font-family:'Space Mono',monospace;font-size:12px;font-weight:700;text-align:center;}
.lb-rank.r1{color:#FFD700;}.lb-rank.r2{color:#C0C0C0;}.lb-rank.r3{color:#CD7F32;}
.lb-player{display:flex;align-items:center;gap:7px;}
.lb-av{font-size:16px;flex-shrink:0;}
.lb-pname{font-size:12px;font-weight:600;display:flex;align-items:center;gap:5px;}
.me-tag{font-size:7px;color:var(--gold);background:rgba(212,175,55,.1);border:1px solid rgba(212,175,55,.2);border-radius:3px;padding:1px 4px;}
.lb-psub{font-size:9px;color:var(--muted);}
.lb-right{text-align:right;}
.lb-elo{font-family:'Space Mono',monospace;font-size:12px;font-weight:700;color:var(--gold);}
.lb-wr{font-size:9px;color:var(--green);}

/* ═══ MATCH HISTORY ═══ */
.match-list{display:flex;flex-direction:column;gap:4px;}
.match-row{display:grid;grid-template-columns:auto 1fr auto;gap:8px;align-items:center;background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:7px 10px;}
.mres{font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px;}
.mres.win{background:rgba(34,216,122,.1);color:var(--green);border:1px solid rgba(34,216,122,.18);}
.mres.loss{background:rgba(248,113,113,.08);color:var(--red);border:1px solid rgba(248,113,113,.15);}
.minfo{font-size:10px;color:var(--muted);line-height:1.4;}
.minfo strong{color:var(--text);}
.melo{font-family:'Space Mono',monospace;font-size:10px;font-weight:700;text-align:right;}
.melo.pos{color:var(--green);}.melo.neg{color:var(--red);}
.empty-state{text-align:center;padding:28px;color:var(--muted);font-size:12px;}
.empty-state .ei{font-size:32px;margin-bottom:8px;}

/* ═══ STATS CARDS ═══ */
.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:8px;}
.stat-card{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:9px 7px;text-align:center;}
.sv{font-family:'Space Mono',monospace;font-size:16px;font-weight:700;}
.sv.gold{color:var(--gold);}.sv.green{color:var(--green);}.sv.red{color:var(--red);}
.sl{font-size:8px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-top:2px;}
.ss{font-size:7px;color:#4A4060;margin-top:1px;}
.wr-bar-wrap{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:10px 12px;margin-bottom:8px;}
.wr-labels{display:flex;justify-content:space-between;font-size:9px;margin-bottom:5px;}
.wr-track{height:8px;background:rgba(248,113,113,.15);border-radius:4px;overflow:hidden;}
.wr-fill{height:100%;background:linear-gradient(90deg,var(--green),#6EE7B7);border-radius:4px;transition:width .6s ease;}

/* ═══ COACH IA ═══ */
.coach-card{background:linear-gradient(135deg,rgba(34,216,122,.06),rgba(139,92,246,.06));border:1px solid rgba(34,216,122,.2);border-radius:14px;padding:14px;margin-bottom:10px;}
.coach-header{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.coach-av{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,rgba(34,216,122,.2),rgba(139,92,246,.2));border:1.5px solid rgba(34,216,122,.35);font-size:20px;display:flex;align-items:center;justify-content:center;flex-shrink:0;animation:coachPulse 2s ease-in-out infinite;}
@keyframes coachPulse{0%,100%{box-shadow:0 0 0 0 rgba(34,216,122,.3)}50%{box-shadow:0 0 0 6px rgba(34,216,122,.0)}}
.coach-title{font-family:'Cinzel',serif;font-size:13px;font-weight:700;color:var(--green);margin-bottom:2px;}
.coach-sub{font-size:9px;color:var(--muted);}
.coach-loading{display:flex;align-items:center;gap:8px;font-size:11px;color:var(--green);font-style:italic;padding:8px 0;}
.coach-dots{display:flex;gap:4px;}
.coach-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:ap .7s ease-in-out infinite;}
.coach-dot:nth-child(2){animation-delay:.2s;}.coach-dot:nth-child(3){animation-delay:.4s;}
.coach-tips{display:flex;flex-direction:column;gap:6px;}
.tip{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:8px;padding:9px 11px;font-size:11px;color:var(--text);line-height:1.6;display:flex;gap:8px;align-items:flex-start;}
.tip-icon{font-size:14px;flex-shrink:0;margin-top:1px;}
.tip-label{font-size:8px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:3px;}
.tip-label.good{color:var(--green);}
.tip-label.improve{color:var(--orange);}
.tip-label.info{color:var(--blue);}
.tip-text{font-size:11px;color:var(--muted);line-height:1.5;}
.coach-score{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-top:10px;}
.cs-card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:8px;padding:8px;text-align:center;}
.cs-val{font-family:'Space Mono',monospace;font-size:16px;font-weight:700;}
.cs-lab{font-size:8px;color:var(--muted);margin-top:2px;}

/* ═══ SPECTATOR ═══ */
.spec-controls{display:flex;gap:6px;margin-bottom:10px;align-items:center;}
.spec-vs{flex:1;text-align:center;font-size:11px;color:var(--muted);}
.spec-vs strong{color:var(--text);}
.spec-score{display:flex;gap:16px;justify-content:center;margin-bottom:8px;}
.spec-sc{text-align:center;}
.spec-sc-val{font-family:'Space Mono',monospace;font-size:24px;font-weight:700;}
.spec-sc-val.red{color:var(--red);}
.spec-sc-val.blue{color:var(--blue);}
.spec-sc-lab{font-size:9px;color:var(--muted);}
.spec-sc-sep{font-family:'Cinzel',serif;font-size:20px;color:var(--muted);line-height:2;}
.spec-log{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:8px;max-height:80px;overflow-y:auto;font-size:10px;color:var(--muted);display:flex;flex-direction:column;gap:3px;}
.spec-log::-webkit-scrollbar{width:2px;}
.spec-log::-webkit-scrollbar-thumb{background:var(--border);}
.spec-log-entry{display:flex;gap:6px;align-items:center;}
.spec-log-entry.red{color:var(--red);}.spec-log-entry.blue{color:var(--blue);}.spec-log-entry.sys{color:var(--muted);}

/* ═══ RISK MODAL ═══ */
.risk-card{max-width:400px;}
.risk-title{font-family:'Cinzel',serif;font-size:16px;font-weight:700;color:var(--orange);margin-bottom:10px;text-align:center;}
.risk-items{display:flex;flex-direction:column;gap:6px;margin-bottom:14px;}
.risk-item{background:rgba(251,146,60,.06);border:1px solid rgba(251,146,60,.15);border-radius:8px;padding:9px 11px;font-size:11px;color:rgba(253,186,116,.8);line-height:1.5;display:flex;gap:8px;align-items:flex-start;}
.risk-icon{font-size:14px;flex-shrink:0;}
.risk-accept{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:8px;padding:10px 12px;cursor:pointer;margin-bottom:14px;}
.risk-checkbox{width:16px;height:16px;border-radius:4px;border:1.5px solid rgba(212,175,55,.4);background:transparent;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:10px;transition:all .2s;}
.risk-checkbox.checked{background:var(--gold-dark);border-color:var(--gold);}
.risk-accept-text{font-size:11px;color:var(--muted);line-height:1.4;}

/* ═══ WIN OVERLAY ═══ */
#win-overlay{position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:300;display:none;align-items:center;justify-content:center;backdrop-filter:blur(10px);}
#win-overlay.show{display:flex;}
.wcard{background:var(--surface);border:1px solid var(--gold-dark);border-radius:18px;padding:24px 20px;text-align:center;max-width:360px;width:90%;box-shadow:0 0 60px rgba(212,175,55,.15);animation:fadeUp .4s ease;}
.wcard.demo{border-color:rgba(139,92,246,.4);}
.wcard.loss{border-color:rgba(248,113,113,.35);}
.wicon{font-size:48px;margin-bottom:6px;}
.wtitle{font-family:'Cinzel',serif;font-size:20px;font-weight:900;background:linear-gradient(135deg,var(--gold-dark),var(--gold-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:3px;}
.wtitle.demo{background:linear-gradient(135deg,var(--purple),#C4B5FD);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.wtitle.loss{background:linear-gradient(135deg,var(--red),#FCA5A5);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.wstake{font-size:17px;font-weight:700;font-family:'Cinzel',serif;margin-bottom:3px;}
.w-elo-row{display:inline-flex;align-items:center;gap:8px;background:rgba(212,175,55,.06);border:1px solid rgba(212,175,55,.15);border-radius:7px;padding:4px 12px;margin-bottom:6px;font-family:'Space Mono',monospace;font-size:11px;}
.w-xp-row{display:inline-flex;align-items:center;gap:6px;background:rgba(252,211,77,.06);border:1px solid rgba(252,211,77,.15);border-radius:7px;padding:4px 12px;margin-bottom:10px;font-size:11px;color:var(--xp);}
.wmsg{font-size:11px;color:var(--muted);margin-bottom:14px;line-height:1.5;}
.wbtns{display:grid;grid-template-columns:1fr 1fr 1fr;gap:5px;}
.wbtn{padding:9px;border-radius:7px;font-size:9px;font-weight:600;cursor:pointer;border:1px solid var(--border);font-family:'Inter',sans-serif;text-transform:uppercase;transition:all .2s;}

/* ═══ MOBILE OPTIMIZATIONS ═══ */
@media(max-width:400px){
  .mgrid{grid-template-columns:repeat(2,1fr);}
  .stats-grid{grid-template-columns:repeat(3,1fr);}
  .wbtns{grid-template-columns:1fr 1fr;}
  .wbtns .wbtn:last-child{grid-column:span 2;}
}
@media(max-height:650px){
  .hud{padding:3px 8px;}
  .phud{padding:4px 8px;}
  .ctrl{padding:4px 7px;}
  .btn{padding:5px 4px;font-size:8px;}
}
</style>
</head>
